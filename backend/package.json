    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-session": "^1.18.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nodemailer": "^7.0.12",
    "pg": "^8.20.0",
